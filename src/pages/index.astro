---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { SITE_TITLE, SITE_DESCRIPTION, AUTHOR } from "../consts";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <section class="intro prose">
    <p class="kicker">// PORTFOLIO + DEVLOG</p>
    <h1>Hey, I'm <span class="neon-text">{AUTHOR.split(" ")[0]}</span>.</h1>
    <p>
      I'm a tech artist and gamedev — I like building small game engines,
      breaking render pipelines, and writing about the graphics rabbit holes I
      fall into. This is where I keep notes on the things I make.
    </p>
    <p class="cta">
      <a href={`${base}/blog`} class="cta-link">Read the blog →</a>
      <a href={`${base}/about`} class="cta-link">More about me →</a>
    </p>
  </section>

  <section class="latest">
    <h2>Latest posts</h2>
    {
      latest.length === 0 ? (
        <p class="muted">No posts yet — check back soon.</p>
      ) : (
        <ul class="post-cards">
          {latest.map((post) => (
            <PostCard post={post} />
          ))}
        </ul>
      )
    }
    <p class="all-link">
      <a href={`${base}/blog`}>All posts →</a>
    </p>
  </section>
</BaseLayout>

<style>
  .intro {
    margin-block: 1rem 3.5rem;
  }
  .cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .cta-link {
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.92rem;
  }
  .latest {
    max-width: var(--measure);
    margin-inline: auto;
  }
  .latest .post-cards {
    margin-top: 1.75rem;
  }
  .all-link {
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 0.9rem;
  }
</style>
