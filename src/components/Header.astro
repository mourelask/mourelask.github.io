---
import { SITE_TITLE, NAV_LINKS } from "../consts";

const base = import.meta.env.BASE_URL;
// Normalize the current path for active-link comparison (strip base + trailing slash).
const stripBase = (p: string) =>
  ("/" + p.replace(base, "").replace(/^\/+/, "")).replace(/\/$/, "") || "/";
const current = stripBase(Astro.url.pathname);

const isActive = (href: string) => {
  if (href === "/") return current === "/";
  return current === href || current.startsWith(href + "/");
};
const withBase = (href: string) =>
  (base.replace(/\/$/, "") + href).replace(/^$/, "/");
---

<header class="site-header">
  <div class="container header-inner">
    <a href={withBase("/")} class="brand">
      <span class="brand-mark">▶</span><span class="brand-name">{SITE_TITLE}</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={withBase(link.href)}
                aria-current={isActive(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg-soft) 80%, transparent);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 0.9rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text);
  }
  .brand-mark {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--cyan);
    text-shadow: 0 0 12px rgba(139, 233, 253, 0.6);
    transition: transform 0.15s ease;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }
  .brand:hover {
    text-decoration: none;
  }
  .brand:hover .brand-name {
    background: var(--neon-gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .brand:hover .brand-mark {
    transform: translateX(2px);
  }
  nav ul {
    list-style: none;
    display: flex;
    gap: 1.6rem;
    margin: 0;
    padding: 0;
  }
  nav a {
    color: var(--text-muted);
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  nav a:hover {
    color: var(--text);
    text-decoration: none;
    text-shadow: var(--glow-accent);
  }
  nav a[aria-current="page"] {
    color: var(--text);
  }
  nav a[aria-current="page"]::after {
    content: "";
    display: block;
    height: 2px;
    background: var(--neon-gradient);
    border-radius: 2px;
    margin-top: 3px;
    box-shadow: 0 0 8px rgba(189, 147, 249, 0.6);
  }
</style>
